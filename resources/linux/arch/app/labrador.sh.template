#!/bin/bash

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-~/.config}

# Allow users to override command-line options
if [[ -f $XDG_CONFIG_HOME/labrador-terminal@@CHANNEL_SUFFIX@@-flags.conf ]]; then
    LABRADOR_USER_FLAGS="$(grep -v '^#' $XDG_CONFIG_HOME/labrador-terminal@@CHANNEL_SUFFIX@@-flags.conf)"
fi

# Launch
exec /opt/labrador/labrador-terminal@@CHANNEL_SUFFIX@@/@@BINARY_NAME@@ $LABRADOR_USER_FLAGS "$@"
