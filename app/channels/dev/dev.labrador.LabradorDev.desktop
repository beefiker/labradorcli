[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=LabradorDev
GenericName=TerminalEmulator

Exec=labrador-terminal-dev %U
StartupWMClass=dev.labrador.LabradorDev

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.labrador.LabradorDev

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for labradordev:// URLs.
MimeType=x-scheme-handler/labradordev;
