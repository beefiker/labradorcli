[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=LabradorPreview
GenericName=TerminalEmulator

Exec=labrador-terminal-preview %U
StartupWMClass=dev.labrador.LabradorPreview

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.labrador.LabradorPreview

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for labradorpreview:// URLs.
MimeType=x-scheme-handler/labradorpreview;
